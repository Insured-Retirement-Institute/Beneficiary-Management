openapi: 3.1.0
info:
  title: Annuity Beneficiary Data Exchange API
  version: 0.0.1
  description: 'Direction-neutral annuity event exchange specification intended for
    use by both Distributors and Carriers.
    
    Any party MAY act as sender by POSTing a BeneficiaryEventEnvelope to the receiver''s
    endpoint.
    
    Business correlation for beneficiary proposal outcome MUST use beneficiaryTransactionId.
    
    Outcomes are communicated asynchronously by the Carrier using BOOKED or REJECTED
    events.'
  contact:
    name: FIA Support
    email: fia-support@fmr.com
servers:
  - url: https://api.fidelity.com
paths:
  /v1/beneficiary/events:
    post:
      summary: Inbound Beneficiary Events
      description: 'Accepts beneficiary proposal (PROPOSED), confirmation (BOOKED),
        and rejection (REJECTED) events.

        A 202 ACCEPTED indicates the event was accepted for processing (idempotency
        + envelope/schema validation).

        Business outcome is communicated asynchronously via BOOKED or REJECTED events
        correlated by beneficiaryTransactionId.'
      operationId: postBeneficiaryEvent
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BeneficiaryEventEnvelope'
      responses:
        '202':
          $ref: '#/components/responses/Accepted'
        '400':
          $ref: '#/components/responses/BadRequest'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '403':
          $ref: '#/components/responses/Forbidden'
        '409':
          $ref: '#/components/responses/Conflict'
        '415':
          $ref: '#/components/responses/UnsupportedMediaType'
        '422':
          $ref: '#/components/responses/UnprocessableEntity'
        '429':
          $ref: '#/components/responses/TooManyRequests'
        '500':
          $ref: '#/components/responses/InternalServerError'
components:
  responses:
    Accepted:
      description: Event accepted for processing
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/EventAck'
    BadRequest:
      description: Invalid request (envelope/schema/required fields)
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
    Unauthorized:
      description: Authentication required or failed
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
    Forbidden:
      description: Authenticated but not permitted
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
    Conflict:
      description: Idempotency conflict (duplicate eventId with different payload)
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
    UnsupportedMediaType:
      description: Unsupported Content-Type
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
    UnprocessableEntity:
      description: Request is syntactically valid but cannot be accepted for processing
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
    TooManyRequests:
      description: Throttled
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
    InternalServerError:
      description: Internal server error
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
  schemas:
    EventEnvelopeBase:
      type: object
      additionalProperties: false
      required:
        - eventId
        - eventType
        - eventTimestamp
        - senderParticipantId
        - receiverParticipantId
        - payload
      properties:
        eventId:
          type: string
          description: Delivery identifier used for idempotency.
        eventType:
          type: string
          description: Fully qualified event type.
        eventTimestamp:
          type: string
          format: date-time
          description: Timestamp when the event was produced (UTC, ISO-8601 with 'Z').
        senderParticipantId:
          type: string
          minLength: 8
          maxLength: 8
          pattern: '^[0-9]{8}$'
          description: Unique identifier for carrier/distributor (NSCC/DTCC participant id).
        receiverParticipantId:
          type: string
          minLength: 8
          maxLength: 8
          pattern: '^[0-9]{8}$'
          description: Unique identifier for carrier/distributor (NSCC/DTCC participant id).
        replayOfEventId:
          type: string
          description: Optional reference to original eventId when replaying/retrying.
        payload:
          type: object
          description: Domain payload. Concrete shape is defined by domain-specific envelopes.

    BeneficiaryEventEnvelope:
      allOf:
        - $ref: '#/components/schemas/EventEnvelopeBase'
        - type: object
          additionalProperties: false
          properties:
            eventType:
              type: string
              enum:
                - insurance.annuity.beneficiary.proposed.v1
                - insurance.annuity.beneficiary.booked.v1
                - insurance.annuity.beneficiary.rejected.v1
            payload:
              $ref: '#/components/schemas/BeneficiaryEvent'

    BeneficiaryEvent:
      description: Beneficiary event payload. Shape depends on beneficiaryEventType.
      oneOf:
        - $ref: '#/components/schemas/BeneficiaryProposedEvent'
        - $ref: '#/components/schemas/BeneficiaryBookedEvent'
        - $ref: '#/components/schemas/BeneficiaryRejectedEvent'
      discriminator:
        propertyName: beneficiaryEventType
        mapping:
          PROPOSED: '#/components/schemas/BeneficiaryProposedEvent'
          BOOKED: '#/components/schemas/BeneficiaryBookedEvent'
          REJECTED: '#/components/schemas/BeneficiaryRejectedEvent'

    BeneficiaryEventBase:
      type: object
      additionalProperties: false
      required:
        - beneficiaryEventId
        - beneficiaryTransactionId
        - beneficiaryEventType
        - sourceSystem
        - processedTimestamp
        - contract
        - beneficiaryAction
        - beneficiaries
      properties:
        beneficiaryEventId:
          type: string
          description: Business identifier for beneficiary event (audit/reconciliation). Not used for idempotency.
        beneficiaryTransactionId:
          type: string
          maxLength: 65
          description: Business transaction identifier that correlates proposed and booked/rejected changes.
        beneficiaryEventType:
          type: string
          enum:
            - PROPOSED
            - BOOKED
            - REJECTED
        sourceSystem:
          type: string
          enum:
            - DISTRIBUTOR
            - CARRIER
        processedTimestamp:
          type: string
          format: date-time
          description: Timestamp when event was processed by originating system (UTC, ISO-8601 with 'Z').
        effectiveDate:
          type: string
          format: date
          description: Effective date of the beneficiary change (optional; carrier authoritative when present).
        requestorContext:
          $ref: '#/components/schemas/RequestorContext'
          description: Context about the role/capacity under which the beneficiary change was requested. Primarily applicable to PROPOSED events and MAY be echoed on BOOKED or REJECTED outcomes for reconciliation.
        beneficiaryAction:
          type: string
          enum:
            - REPLACE_BENEFICIARY
          description: Replace-all semantics.
        contract:
          $ref: '#/components/schemas/Contract'
        beneficiaries:
          type: array
          minItems: 1
          items:
            $ref: '#/components/schemas/Beneficiary'

    BeneficiaryProposedEvent:
      allOf:
        - $ref: '#/components/schemas/BeneficiaryEventBase'
        - type: object
          properties:
            beneficiaryEventType:
              type: string
              enum:
                - PROPOSED

    BeneficiaryBookedEvent:
      allOf:
        - $ref: '#/components/schemas/BeneficiaryEventBase'
        - type: object
          properties:
            beneficiaryEventType:
              type: string
              enum:
                - BOOKED

    BeneficiaryRejectedEvent:
      allOf:
        - $ref: '#/components/schemas/BeneficiaryEventBase'
        - type: object
          required:
            - rejection
          properties:
            beneficiaryEventType:
              type: string
              enum:
                - REJECTED
            rejection:
              $ref: '#/components/schemas/RejectionDetails'

    RequestorContext:
      type: object
      additionalProperties: false
      properties:
        requestorRole:
          type: string
          description: Role/capacity of the party requesting the beneficiary change.
          enum:
            - OWNER
            - POWER_OF_ATTORNEY
            - TRUSTEE
            - ANNUITANT
            - AUTHORIZED_REPRESENTATIVE
        authorityType:
          type: string
          description: Type of authority/documentation being relied upon when the requestor is acting on behalf of the owner.
          enum:
            - POA
            - TRUST_DOCUMENTATION
            - COURT_ORDER
            - GUARDIANSHIP
            - OTHER
        authorityReference:
          type: string
          description: Reference to supporting authority documentation (for example a document ID, case number, or external document reference).
        submissionChannel:
          type: string
          description: Originating channel from which the request was submitted.
          enum:
            - FIDELITY_UI
            - ADVISOR_PORTAL
            - CALL_CENTER
            - CARRIER_PORTAL
            - OTHER
        requestedByPartyId:
          type: string
          description: Optional stable party identifier for the requestor when available.

    RejectionDetails:
      type: object
      additionalProperties: false
      required:
        - rejectionCode
        - rejectionMessage
      properties:
        rejectionCode:
          $ref: '#/components/schemas/BeneficiaryDxErrorCode'
        rejectionMessage:
          type: string
          maxLength: 500
        fieldErrors:
          type: array
          items:
            $ref: '#/components/schemas/FieldError'

    FieldError:
      type: object
      additionalProperties: false
      required:
        - path
        - message
      properties:
        path:
          type: string
          description: JSONPath-like pointer (for example $.beneficiaries[0].percent).
        code:
          $ref: '#/components/schemas/BeneficiaryDxErrorCode'
        message:
          type: string

    Contract:
      type: object
      additionalProperties: false
      required:
        - contractNumber
      properties:
        contractNumber:
          type: string
        associatedFirmId:
          type: string

    Beneficiary:
      type: object
      additionalProperties: false
      required:
        - beneficiaryType
        - relationship
        - designationAmountType
        - name
      properties:
        beneficiaryId:
          type: string
        beneficiaryType:
          type: string
          enum:
            - PRIMARY
            - CONTINGENT
            - TERTIARY
        relationship:
          type: string
        designationAmountType:
          type: string
          enum:
            - PERCENT
            - EQUAL_SHARES
        designationSuccessionType:
          type: string
          enum:
            - PER_CAPITA
            - PER_STIRPES
        percent:
          type: number
          minimum: 0
          maximum: 100
        irrevocable:
          type: boolean
        dob:
          type: string
          format: date
        name:
          $ref: '#/components/schemas/BeneficiaryName'
        address:
          $ref: '#/components/schemas/Address'
        phones:
          type: array
          items:
            $ref: '#/components/schemas/Phone'
        emails:
          type: array
          items:
            $ref: '#/components/schemas/Email'

    BeneficiaryName:
      type: object
      additionalProperties: false
      properties:
        firstName:
          type: string
          maxLength: 100
        middleName:
          type: string
          maxLength: 100
        lastName:
          type: string
          maxLength: 100
        entityName:
          type: string
          maxLength: 180
      oneOf:
        - required:
            - firstName
            - lastName
        - required:
            - entityName

    Address:
      type: object
      additionalProperties: false
      required:
        - addressType
        - addressLine1
        - city
        - state
        - zipCode
      properties:
        addressId:
          type: string
          maxLength: 100
        addressType:
          type: string
          maxLength: 30
          enum:
            - RESIDENCE
            - BUSINESS
            - POBOXSEASONAL
            - APO
            - DPO
            - FPO
        addressLine1:
          type: string
          maxLength: 100
        addressLine2:
          type: string
          maxLength: 100
        addressLine3:
          type: string
          maxLength: 100
        addressLine4:
          type: string
          maxLength: 100
        addressLine5:
          type: string
          maxLength: 100
        city:
          type: string
          maxLength: 100
        state:
          type: string
          maxLength: 2
          pattern: '^[A-Z]{2}$'
        zipCode:
          type: string
          maxLength: 10
          pattern: '^[0-9A-Za-z -]{3,10}$'
        zipCodeExtension:
          type: string
          maxLength: 4
          pattern: '^[0-9A-Za-z]{1,4}$'
        country:
          type: string
          maxLength: 2
          pattern: '^[A-Z]{2}$'

    Phone:
      type: object
      additionalProperties: false
      required:
        - countryCode
        - areaCode
        - dialNumber
      properties:
        startDate:
          type: string
          format: date
        endDate:
          type: string
          format: date
        phoneType:
          type: string
          enum:
            - MOBILE
            - HOME
            - BUSINESS
            - CLAIMCENTER
            - CUSTOMERSERVICE
            - CORPORATEOFFICE
            - FAX
            - UNKNOWN
            - OTHER
        countryCode:
          type: string
          pattern: '^\+?[0-9]{1,3}$'
        areaCode:
          type: string
          pattern: '^[0-9]{2,5}$'
          description: Supports domestic and international numbering plans; 2 to 5 digits are allowed.
        dialNumber:
          type: string
          pattern: '^[0-9]{4,12}$'
        extension:
          type: string
          pattern: '^[A-Za-z0-9-]{1,10}$'
        bestTime:
          type: string
          enum:
            - MORNING
            - AFTERNOON
            - EVENING
            - ANYTIME
        timezone:
          type: string
          pattern: '^[A-Za-z_]+/[A-Za-z_]+(?:/[A-Za-z_]+)?$'
        isPreferred:
          type: boolean
        phoneId:
          type: string
          pattern: '^[A-Za-z0-9._-]{1,100}$'

    Email:
      type: object
      additionalProperties: false
      required:
        - emailAddress
      properties:
        startDate:
          type: string
          format: date
        endDate:
          type: string
          format: date
        emailType:
          type: string
          enum:
            - PERSONAL
            - BUSINESS
            - CUSTOMERSERVICE
            - OTHER
        emailAddress:
          type: string
          format: email
          pattern: '^[^@\s]+@[^@\s]+\.[^@\s]+$'
        isPreferred:
          type: boolean
        emailId:
          type: string
          pattern: '^[A-Za-z0-9._-]{1,100}$'

    EventAck:
      type: object
      additionalProperties: false
      required:
        - status
      properties:
        status:
          type: string
          enum:
            - ACCEPTED
        receivedTimestamp:
          type: string
          format: date-time

    ErrorResponse:
      type: object
      additionalProperties: false
      required:
        - errorCode
        - errorMessage
      properties:
        errorCode:
          $ref: '#/components/schemas/BeneficiaryDxErrorCode'
        errorMessage:
          type: string
        errorDetails:
          type: array
          items:
            $ref: '#/components/schemas/FieldError'

    BeneficiaryDxErrorCode:
      type: string
      description: Standard error codes for beneficiary data exchange.
      enum:
        - DX_INVALID_REQUEST
        - DX_UNSUPPORTED_MEDIA_TYPE
        - DX_UNSUPPORTED_EVENT_TYPE
        - DX_DUPLICATE_EVENT_ID
        - DX_UNAUTHORIZED
        - DX_FORBIDDEN
        - DX_RATE_LIMITED
        - DX_UNPROCESSABLE
        - DX_INTERNAL_ERROR
        - BENE_CONTRACT_NOT_FOUND
        - BENE_CONTRACT_NOT_ELIGIBLE
        - BENE_PENDING_TRANSACTION_EXISTS
        - BENE_ALLOCATION_INVALID
        - BENE_INVALID_BENEFICIARY
        - BENE_INVALID_RELATIONSHIP
        - BENE_IRREVOCABLE_CONSTRAINT
        - BENE_EFFECTIVE_DATE_INVALID
